# ============================================================
# Mineral Rush — 환경 변수 예시
# 이 파일을 복사해서 .env 를 만드세요: cp .env.example .env
# .env 는 절대 git 커밋하지 마세요 (.gitignore 에 등록됨)
# ============================================================

# ── 게임 빌드 정보 ─────────────────────────────────────────
# 앱 버전 (semver). DebugBar, PlaytestPanel, IBootConfig 강제 업데이트 비교에 사용.
VITE_GAME_VERSION=0.0.1

# ── 보안: 저장 데이터 서명 ────────────────────────────────
# 로컬 저장소(localStorage) HMAC-SHA256 서명 키.
# 개발용: 임의 문자열 가능.
# 프로덕션: 최소 32자 이상 랜덤 문자열, 절대 노출 금지.
# Phase 4 이후: 서버 서명으로 교체 예정 (클라에서 제거).
VITE_DEV_HMAC_SECRET=change-me-to-a-long-random-secret

# ── Supabase (Phase 4+ 활성화) ────────────────────────────
# 현재(Phase 2): StubBootConfigSource / StubRunSubmitter 사용 → 없어도 동작.
# Phase 4 배포 시 실제 값으로 교체.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

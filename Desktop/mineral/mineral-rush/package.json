{
  "name": "mineral-rush",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Mineral Rush — 광물 채굴 액션/로그라이트 게임",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "sim": "tsx tools/balance-sim.ts",
    "sim:1k": "tsx tools/balance-sim.ts --runs 1000",
    "sim:no-cards": "tsx tools/balance-sim.ts --runs 1000 --pickCards false",
    "validate-content": "tsx tools/content-validator.ts",
    "bundle:edge": "tsx tools/bundle-edge-fn.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "pixi.js": "^8.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "@vitejs/plugin-react": "^4.3.3",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.1",
    "eslint-plugin-boundaries": "^4.2.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "jsdom": "^25.0.1",
    "prettier": "^3.3.3",
    "tsx": "^4.19.0",
    "typescript": "~5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  }
}
